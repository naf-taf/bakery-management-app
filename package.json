{
  "name": "bakery-app",
  "version": "1.0.1",
  "description": "Desktop application for bakery management",
  "author": "Bakery Management",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:react": "cd src/renderer && npm start",
    "build": "cd src/renderer && npm run build",
    "dist": "npm run build && electron-builder --publish never"
  },
  "build": {
    "appId": "com.bakery.management",
    "productName": "Bakery Management",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "src/main/**/*",
      "src/renderer/build/**/*",
      "db/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "glob": "^11.0.0",
    "tar": "^7.0.0",
    "inflight": "^1.0.6",
    "prebuild-install": "latest"
  }
}
