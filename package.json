{
  "name": "bakery-app",
  "version": "1.0.0",
  "description": "Desktop application for bakery management",
  "author": "Bakery Management",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:react": "cd src/renderer && npm start",
    "build": "cd src/renderer && npm run build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.bakery.management",
    "productName": "Bakery Management",
    "directories": {
      "output": "dist"
    },
    "files": [
      "package.json",
      "src/main/**/*",
      "src/renderer/build/**/*",
      "db/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^24.4.0",
    "electron-builder": "^24.6.4",
    "wait-on": "^7.0.1"
  }
}
